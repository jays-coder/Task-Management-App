@model List<TaskManagement.Models.TaskItem>
@{
    ViewData["Title"] = "Index";
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Index</title>
    <!-- Bootstrap 5 CSS CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- jQuery CDN -->
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>

    <!-- Bootstrap 5 JS CDN -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
    <div class="container mt-4">

        <h2 class="mb-3">Task Management</h2>

       
        <button class="btn btn-primary mb-3" onclick="openCreateModal()">
            + Add Task
        </button>

   <input type="text" id="searchInput" class="form-control mb-3" placeholder="Search tasks...">
        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Status</th>
                    <th>Due Date</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>@item.Status</td>
                        <td>@item.DueDate.ToShortDateString()</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1"
                                    onclick="editTask(@item.Id, '@item.Title', '@item.Description', '@item.DueDate.ToString("yyyy-MM-dd")', '@item.Status', '@item.Remarks')">
                                Edit
                            </button>
                            <button class="btn btn-warning btn-sm me-1"
                                    onclick="viewTask(@item.Id, '@item.Title', '@item.Description', '@item.DueDate.ToString("yyyy-MM-dd")', '@item.Status', '@item.Remarks')">
                                View
                            </button>

                            <a href="/Task/Delete/@item.Id"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('Are you sure?')">
                                Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

   
    <div class="modal fade" id="taskModal">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle">Add Task</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <form id="taskForm" method="post" action="/Task/Create">

                    <div class="modal-body">

                        <input type="hidden" id="Id" name="Id" />

                        <div class="mb-2">
                            <label>Title</label>
                            <input type="text" id="Title" name="Title" class="form-control" />
                        </div>

                        <div class="mb-2">
                            <label>Description</label>
                            <input type="text" id="Description" name="Description" class="form-control" />
                        </div>

                        <div class="mb-2">
                            <label>Due Date</label>
                            <input type="date" id="DueDate" name="DueDate" class="form-control" />
                        </div>

                        <div class="mb-2">
                            <label>Status</label>
                            <select id="Status" name="Status" class="form-control">
                                <option value="">--Select--</option>
                                <option>Pending</option>
                                <option>Completed</option>
                            </select>
                        </div>

                        <div class="mb-2">
                            <label>Remarks</label>
                            <input type="text" id="Remarks" name="Remarks" class="form-control" />
                        </div>

                    </div>

                    <div class="modal-footer d-flex justify-content-between align-items-center">

                        
                        <span id="formMessage" class="text-danger"></span>

                        
                        <button type="submit" class="btn btn-success">Save</button>

                    </div>

                </form>

            </div>
        </div>
    </div>

</body>
<script>
        
        function openCreateModal() {
            document.getElementById('modalTitle').innerText = 'Add Task';
            document.getElementById('taskForm').reset();
            $("#taskForm input, #taskForm select").removeClass("border-danger");
                $("#taskForm input, #taskForm select").prop("disabled", false);
             $("#taskForm button").prop("hidden", false);
            document.getElementById('Id').value = '';
            document.getElementById('taskForm').action = '/Task/Create';

            var myModal = new bootstrap.Modal(document.getElementById('taskModal'));
            myModal.show();
        }

    $("#taskForm").submit(function (e) {
        e.preventDefault(); 
        var title = $("#Title").val();
        var dueDate = $("#DueDate").val();
        var status = $("#Status").val();
        var remarks=$("#Remarks").val();

    $("#formMessage").text(""); 
    $("#taskForm input, #taskForm select").removeClass("border-danger");

    if (!title || title.trim() === "") {
        $("#Title").addClass("border-danger");
        $("#formMessage")
            .text("Title is required")
            .removeClass("text-success")
            .addClass("text-danger");
        return;
    }

    if (!remarks || remarks.trim() === "") {
        $("#Remarks").addClass("border-danger");
        $("#formMessage")
            .text("Remarks is required")
            .removeClass("text-success")
            .addClass("text-danger");
        return;
    }

    if (!dueDate) {
        $("#DueDate").addClass("border-danger");
        $("#formMessage")
            .text("Date is required")
            .removeClass("text-success")
            .addClass("text-danger");
        return;
    }

    if (!status) {
        $("#Status").addClass("border-danger");
        $("#formMessage")
            .text("Please select status")
            .removeClass("text-success")
            .addClass("text-danger");
        return;
    }

        var formData = {
            Id: $("#Id").val(),
            Title: $("#Title").val(),
            Description: $("#Description").val(),
            DueDate: $("#DueDate").val(),
            Status: $("#Status").val(),
            Remarks: $("#Remarks").val()
        };

        $.ajax({
            url: $("#taskForm").attr("action"), 
            type: "POST",
            data: formData,
            success: function (response) {
                debugger;
                $("#formMessage")
                .text("Save successfully")
                .removeClass("text-danger")
                .addClass("text-success");
                location.reload(); 
            },
            error: function () {
                alert("Error occurred");
            }
        });
    });

    function editTask(id, title, desc, dueDate, status, remarks) {
        $("#modalTitle").text("Edit Task");
        $("#taskForm").attr("action", "/Task/Edit");

        $("#Id").val(id);
        $("#Title").val(title);
        $("#Description").val(desc);
        $("#DueDate").val(dueDate);
        $("#Status").val(status);
        $("#Remarks").val(remarks);
        var myModal = new bootstrap.Modal(document.getElementById('taskModal'));
        myModal.show();
    }
    function viewTask(id, title, desc, dueDate, status, remarks) {
        $("#modalTitle").text("View Task");
        //$("#taskForm").attr("action", "/Task/Edit");

        $("#Id").val(id);
        $("#Title").val(title);
        $("#Description").val(desc);
        $("#DueDate").val(dueDate);
        $("#Status").val(status);
        $("#Remarks").val(remarks);
         $("#taskForm input, #taskForm select").prop("disabled", true);
         $("#taskForm button").prop("hidden", true);
        var myModal = new bootstrap.Modal(document.getElementById('taskModal'));
        myModal.show();
    }

    $("#searchInput").on("keyup", function () {
    var value = $(this).val().toLowerCase();

    $("table tbody tr").filter(function () {
        $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
    });
});
</script>
</html>
